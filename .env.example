# Web3Forms access key — get yours free at https://web3forms.com
# 1. Go to https://web3forms.com → enter your recipient email → copy the access key
# 2. Create a `.env` file in this directory and paste the key below
VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Recipient email for form submissions (used as a label in the form, actual
# delivery address is configured inside your Web3Forms dashboard)
VITE_CONTACT_TO_EMAIL=dylan@adongroup.com.au
